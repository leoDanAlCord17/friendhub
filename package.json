{
  "name": "termpals",
  "displayName": "TermPals",
  "description": "Connect with other developers directly from VS Code. Match by tech stack, chat in real time, and find your next collaborator without leaving your editor.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0",
    "node": "24.x"
  },
  "icon": "icon.png",
  "publisher": "leodanielalvarez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leoDanAlCord17/termpals.git"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "developer",
    "networking",
    "social",
    "collaboration",
    "chat",
    "match",
    "github",
    "pair programming"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onUri"
  ],
  "contributes": {
    "uriHandlers": [
      {}
    ],
    "commands": [
      {
        "command": "tp.open",
        "title": "TermPals: Abrir panel",
        "category": "TermPals"
      },
      {
        "command": "tp.login",
        "title": "TermPals: Iniciar sesión con GitHub",
        "category": "TermPals"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "termpals",
          "title": "TermPals",
          "icon": "$(organization)"
        }
      ]
    },
    "views": {
      "termpals": [
        {
          "id": "termpals.main",
          "name": "termpals",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "npm run compile -- --watch",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "vscode-nls": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
