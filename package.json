{
  "name": "termpals",
  "displayName": "TermPals",
  "description": "Conecta con otros desarrolladores desde el panel inferior de VS Code.",
  "version": "0.0.1",
  "publisher": "leodanielalvarez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leodanielalvarez/meethub.git"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": "20.x"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "contributes": {
    "uriHandlers": [
      {}
    ],
    "commands": [
      {
        "command": "tp.open",
        "title": "TermPals: Abrir panel",
        "category": "TermPals"
      },
      {
        "command": "tp.login",
        "title": "TermPals: Iniciar sesión con GitHub",
        "category": "TermPals"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "termpals",
          "title": "TermPals",
          "icon": "$(organization)"
        }
      ]
    },
    "views": {
      "termpals": [
        {
          "id": "termpals.main",
          "name": "termpals",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "TermPals",
      "properties": {
        "termpals.supabaseUrl": {
          "type": "string",
          "default": "",
          "description": "URL de tu proyecto Supabase"
        },
        "termpals.supabaseAnonKey": {
          "type": "string",
          "default": "",
          "description": "Anon key de tu proyecto Supabase"
        },
        "termpals.githubClientId": {
          "type": "string",
          "default": "",
          "description": "Client ID de tu GitHub OAuth App"
        },
        "termpals.githubClientSecret": {
          "type": "string",
          "default": "",
          "description": "Client Secret de tu GitHub OAuth App"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "npm run compile -- --watch",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
